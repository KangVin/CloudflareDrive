{
  "name": "cloudflare-drive",
  "private": true,
  "type": "module",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd",
      "sharp"
    ],
    "nodeLinker": "hoisted"
  },
  "scripts": {
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:worker": "pnpm --filter worker dev",
    "build:frontend": "pnpm --filter frontend build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "pnpm --filter frontend typecheck && pnpm --filter worker typecheck",
    "test": "pnpm --filter frontend test && pnpm --filter worker test",
    "format": "prettier --write \"**/*.{ts,vue,jsonc,json,md,yaml,yml,html,css}\"",
    "format:check": "prettier --check \"**/*.{ts,vue,jsonc,json,md,yaml,yml,html,css}\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.60.1",
    "vue-eslint-parser": "^10.4.1"
  }
}
